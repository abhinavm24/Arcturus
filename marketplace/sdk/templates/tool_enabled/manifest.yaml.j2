# Bazaar Skill Manifest — tool_enabled template
name: {{ skill_name }}
version: "1.0.0"
description: "TODO: describe what {{ skill_name }} does"
author: "{{ author }}"
category: "productivity"
permissions:
  - network            # declared because the tool calls an external API
dependencies:
  - "httpx>=0.27"      # async-friendly HTTP client
skill_dependencies: []
intent_triggers:
  - "{{ skill_name }}"
tools:
  - name: run_{{ skill_name }}
    description: "TODO: describe this tool"
    module: "{{ skill_name }}.tools.main"
    function: "run"
    parameters:
      query:
        type: string
        description: "Search or lookup query"
checksum: ""