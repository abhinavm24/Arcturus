# Copy this file to .env and fill real values locally.
# Never commit .env with real secrets.

GEMINI_API_KEY=

# Neo4j Knowledge Graph (P11 Mnemo Phase 2/3)
# Match docker-compose: NEO4J_AUTH=neo4j/arcturus-neo4j
# NEO4J_ENABLED=true
# NEO4J_URI=bolt://localhost:7687
# NEO4J_USER=neo4j
# NEO4J_PASSWORD=arcturus-neo4j

# P11 Phase 5 Auth: JWT signing secret (HS256). Required for login/register. Generate with: openssl rand -base64 48
# MNEMO_SECRET_KEY=

# P11 Mnemo unified extraction: when true, use unified extractor + Neo4j Fact/Evidence; when false, use legacy RemMe extractor, normalizer, and JSON hubs.
# MNEMO_ENABLED=true

# Async KG ingest: when true, run Neo4j entity extraction in background after Qdrant upsert (faster add latency; graph lags slightly).
# ASYNC_KG_INGEST=false

# P11 Phase 4 Sync Engine: cross-device sync (push/pull). Same server can act as both "device" and "sync server" for local testing.
# SYNC_ENGINE_ENABLED=true
# SYNC_SERVER_URL=http://localhost:8000/api
# DEVICE_ID=  (optional; auto-generated and cached in memory/remme_index/device_id.json if not set)

# Gateway admin secret for /api/v1/keys* management endpoints.
# Must be explicitly set per environment. No default/fallback is used.
ARCTURUS_GATEWAY_ADMIN_KEY=

# Gateway webhook signing secret for /api/v1/webhooks/inbound/*.
# Must be explicitly set for inbound signature verification (fail-closed when unset).
ARCTURUS_GATEWAY_WEBHOOK_SIGNING_SECRET=

# Connector-specific inbound webhook auth (dual-mode with gateway signature path).
# GitHub: validates x-hub-signature-256 against raw request body.
ARCTURUS_GATEWAY_GITHUB_WEBHOOK_SECRET=
# Jira: validates x-atlassian-webhook-token header.
ARCTURUS_GATEWAY_JIRA_WEBHOOK_TOKEN=
# Gmail Pub/Sub push: validates x-goog-channel-token header.
ARCTURUS_GATEWAY_GMAIL_CHANNEL_TOKEN=

# Gateway idempotency and usage governance are enforced per API key by default.
# Configure per-key quotas via /api/v1/keys payloads (monthly_request_quota, monthly_unit_quota).

# Telegram channel adapter
TELEGRAM_TOKEN=

# Slack channel adapter
SLACK_BOT_TOKEN=
SLACK_SIGNING_SECRET=

# Discord channel adapter
DISCORD_BOT_TOKEN=
DISCORD_PUBLIC_KEY=

# WhatsApp Baileys bridge (whatsapp_bridge/)
# URL of the local Node.js bridge HTTP server (must be running separately)
WHATSAPP_BRIDGE_URL=http://localhost:3001
# Shared HMAC-SHA256 secret for bridge ↔ FastAPI authentication
# Leave empty to disable signature verification (dev mode only)
WHATSAPP_BRIDGE_SECRET=

# Google Chat channel adapter
# Webhook mode (simple — no GCP project needed): set GOOGLE_CHAT_WEBHOOK_URL only.
# Service account mode (full API access): set GOOGLE_CHAT_SERVICE_ACCOUNT_TOKEN.
# Get webhook URL from: Google Chat Space → Manage webhooks → Add webhook
GOOGLE_CHAT_WEBHOOK_URL=
# OAuth2 bearer token from service account (for full Chat API access)
GOOGLE_CHAT_SERVICE_ACCOUNT_TOKEN=
# Verification token for validating inbound events (from Google Cloud Console)
# Leave empty to disable token verification (dev mode only)
GOOGLE_CHAT_VERIFICATION_TOKEN=

# iMessage / BlueBubbles channel adapter
# Requires BlueBubbles server (https://bluebubbles.app) running on a Mac with iMessage.
# BlueBubbles settings → Private API + Webhook → add http://<host>:8000/api/nexus/imessage/inbound
BLUEBUBBLES_URL=http://localhost:1234
BLUEBUBBLES_PASSWORD=
# Optional: shared HMAC-SHA256 secret for inbound webhook auth (set in BlueBubbles webhooks)
BLUEBUBBLES_WEBHOOK_SECRET=

# Microsoft Teams channel adapter (Bot Framework)
# Register at: https://dev.botframework.com / Azure Portal → Bot Services
# Set the messaging endpoint to: http://<your-host>:8000/api/nexus/teams/events
TEAMS_APP_ID=
TEAMS_APP_PASSWORD=
# Bot Framework service URL (set dynamically from inbound Activity serviceUrl;
# configure here only if you need a fixed override for outbound sends)
TEAMS_SERVICE_URL=https://smba.trafficmanager.net/apis

# Signal channel adapter (signal-cli sidecar)
# Requires: signal-cli ≥ 0.13 + Java 17 (https://github.com/AsamK/signal-cli)
# 1. Register: signal-cli -a +E164 register && signal-cli -a +E164 verify CODE
#    OR link: signal-cli link -n "Arcturus Bot"
# 2. Run daemon: signal-cli -a +E164 daemon --http
# 3. Run bridge: cd signal_bridge && python app.py
SIGNAL_BRIDGE_URL=http://localhost:3002
# Shared HMAC-SHA256 secret — set same value in signal_bridge SIGNAL_BRIDGE_SECRET
# Leave empty to disable signature verification (dev mode only)
SIGNAL_BRIDGE_SECRET=
# Phone number registered with signal-cli (+E.164, e.g. +15551234567)
SIGNAL_PHONE_NUMBER=
# signal-cli HTTP daemon URL (used by signal_bridge/app.py only)
SIGNAL_CLI_URL=http://localhost:8080

# Matrix channel adapter (Matrix CS API v3)
# Homeserver: matrix.org, Element, or self-hosted Synapse (no sidecar needed)
# 1. Create a bot account on any homeserver
# 2. Get access token: POST {homeserver}/_matrix/client/v3/login
#      {"type": "m.login.password", "user": "@bot:matrix.org", "password": "..."}
# 3. Invite the bot to rooms where it should respond
MATRIX_HOMESERVER_URL=https://matrix.org
MATRIX_USER_ID=@arcturus:matrix.org
MATRIX_ACCESS_TOKEN=
# Seconds between /sync polls (default 2.0 — gives 0-2s inbound latency)
MATRIX_SYNC_INTERVAL=2.0

# Arcturus base URL (used by create_runs_agent to call the local runs API)
ARCTURUS_BASE_URL=http://localhost:8000

# Local migration only: FE guest-id from server + backend user_id file fallback for migration scripts.Enable this to automatically migrate legacy offline data on startup
# Must be false in production and for multi-user. Set true only when running local migrations (e.g. migrate_all_memories.py).
# VITE_ENABLE_LOCAL_MIGRATION=false

# Episodic memory store: qdrant (default) | legacy. Use legacy when not yet migrated to Qdrant; reads/writes memory/episodic_skeletons/skeleton_*.json.
# EPISODIC_STORE_PROVIDER=qdrant