# Copy this file to .env and fill real values locally.
# Never commit .env with real secrets.

GEMINI_API_KEY=

# Neo4j Knowledge Graph (P11 Mnemo Phase 3)
# NEO4J_ENABLED=true
# NEO4J_URI=bolt://localhost:7687
# NEO4J_USER=neo4j
# NEO4J_PASSWORD=

# Gateway admin secret for /api/v1/keys* management endpoints.
# Must be explicitly set per environment. No default/fallback is used.
ARCTURUS_GATEWAY_ADMIN_KEY=

# Gateway webhook signing secret for /api/v1/webhooks/inbound/*.
# Must be explicitly set for inbound signature verification (fail-closed when unset).
ARCTURUS_GATEWAY_WEBHOOK_SIGNING_SECRET=
